    "/stats/summary": {
      "get": {
        "tags": ["Analytics"],
        "summary": "Get summary KPIs",
        "parameters": [
          { "$ref": "#/components/parameters/StartDateParam" },
          { "$ref": "#/components/parameters/EndDateParam" },
          { "name": "period", "in": "query", "schema": { "type": "string", "enum": ["daily", "weekly", "monthly"] } },
          { "$ref": "#/components/parameters/CityParam" },
          { "$ref": "#/components/parameters/CinemaIdQueryParam" },
          { "name": "studio_id", "in": "query", "schema": { "type": "string" } },
          { "name": "compare", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": {
            "description": "Summary analytics",
            "headers": {
              "X-Cache": {
                "description": "Cache status for this response: HIT, MISS, or BYPASS.",
                "schema": { "type": "string", "example": "MISS" }
              }
            },
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" },
                "example": {
                  "success": true,
                  "data": {
                    "total_tickets": 7847,
                    "total_capacity": 36000,
                    "revenue": 318897536,
                    "avg_occupancy": 19.81,
                    "total_transactions": 936,
                    "cinema_aktif": 20,
                    "cinema_tersedia": 20,
                    "growth": {
                      "tickets": 10.01,
                      "revenue": 17.6,
                      "avg_occupancy": 1.59
                    }
                  },
                  "meta": {
                    "period": "2026-04-07 to 2026-04-07",
                    "filters": {
                      "city": null,
                      "cinema_id": null,
                      "studio_id": null
                    },
                    "scope": "global",
                    "compare": true
                  }
                }
              }
            }
          }
        }
      }
    },
    "/stats/trends": {
      "get": {
        "tags": ["Analytics"],
        "summary": "Get trend breakdown",
        "parameters": [
          { "$ref": "#/components/parameters/StartDateParam" },
          { "$ref": "#/components/parameters/EndDateParam" },
          { "name": "group_by", "in": "query", "schema": { "type": "string", "enum": ["hourly", "daily"] } },
          { "$ref": "#/components/parameters/CityParam" },
          { "$ref": "#/components/parameters/CinemaIdQueryParam" },
          { "name": "movie_id", "in": "query", "schema": { "type": "string" } },
