{
  "openapi": "3.1.0",
  "info": {
    "title": "CineTrack API",
    "version": "1.0.0",
    "description": "OpenAPI specification for the CineTrack Fastify backend."
  },
  "servers": [
    {
      "url": "http://localhost:8000/api/v1",
      "description": "Local development"
    }
  ],
  "tags": [
    { "name": "System" },
    { "name": "Auth" },
    { "name": "Movies" },
    { "name": "Cinemas" },
    { "name": "Studios" },
    { "name": "Schedules" },
    { "name": "Tikets" },
    { "name": "Analytics" },
    { "name": "Notifications" },
    { "name": "Settings" }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": ["System"],
        "summary": "Check API availability",
        "responses": {
          "200": {
            "description": "API is running",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" },
                "example": {
                  "success": true,
                  "data": {
                    "message": "Cinema Analytics API is running"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/system/health": {
      "get": {
        "tags": ["System"],
        "summary": "Get backend health details",
        "responses": {
          "200": {
            "description": "Health is active",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" },
                "example": {
                  "success": true,
                  "data": {
                    "status": "active",
                    "last_data_in": "2026-05-14T12:00:00.000Z",
                    "tickets_last_hour": 367961
                  }
                }
              }
            }
          },
          "503": {
            "description": "Database or service unavailable",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" },
                "example": {
                  "success": true,
                  "data": {
                    "status": "inactive",
                    "last_data_in": null,
                    "tickets_last_hour": 0
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login admin user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login success",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" },
                "example": {
                  "success": true,
                  "data": {
                    "token": "access-token",
                    "refresh_token": "refresh-token",
                    "user": {
                      "id": "A001",
                      "name": "Admin",
                      "email": "admin@gmail.com",
                      "role": "admin"
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/ErrorResponse" },
          "422": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["Auth"],
        "summary": "Refresh access token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RefreshRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token refreshed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" },
                "example": {
                  "success": true,
                  "data": {
                    "token": "new-access-token",
                    "refresh_token": "new-refresh-token",
                    "user": {
                      "id": "A001",
                      "name": "Admin",
                      "email": "admin@gmail.com",
                      "role": "admin"
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout admin user",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LogoutRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logout success",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" },
                "example": {
                  "success": true,
                  "data": {
                    "message": "Logout success"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get current authenticated admin",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Current user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" },
                "example": {
                  "success": true,
                  "data": {
                    "id": "A001",
                    "name": "Admin",
                    "email": "admin@gmail.com",
                    "role": "admin"
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
    "/movies": {
      "get": {
        "tags": ["Movies"],
        "summary": "List movies",
        "parameters": [
          { "$ref": "#/components/parameters/PageParam" },
          { "$ref": "#/components/parameters/LimitParam" },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "genre", "in": "query", "schema": { "type": "string" } },
          { "name": "rating_usia", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Movie list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessEnvelope" },
                "example": {
                  "success": true,
                  "data": [
                    {
                      "movie_id": "M003",
                      "title": "Agak Laen",
                      "genre": ["Comedy"],
                      "rating_usia": "R13",
                      "duration_min": 132
                    }
                  ],
                  "meta": {
                    "filters": {
                      "search": null,
                      "genre": null,
                      "rating_usia": null
                    },
                    "pagination": {
                      "page": 1,
                      "limit": 20,
                      "total": 12,
                      "total_pages": 1
                    }
                  }
                }
              }
            }
          },
          "422": { "$ref": "#/components/responses/ErrorResponse" }
        }
      }
    },
